# Download via: python scripts/download_weights.py
Weights/
*.pt
*.ts
*.onnx
*.pkl

# IDE
.vscode/
.idea/
*.swp
*.swo

# Visual Prompt files (contain user-specific paths)
*.vp.json

# Environment
.env
venv/

# Embedded third-party caches
.ruff_cache/

# Upstream demo assets (large GIFs/images)
Plugins/GazeTracking/Gazelle/gazelle/assets/

# Test data (large video files)
test_data/

# Project input videos
Projects/*/Inputs/Videos/

# Superpowers/presentation working material (not part of codebase)
.superpowers/
docs/superpowers/
assets/presentation/

# MkDocs build output
site/

# Local-only reference material (draft plans, baselines) -- not tracked
localref/

# Git worktrees (isolated branch workspaces)
.worktrees/

# Wheel-build resource staging (scripts/sync_bundled_resources.py)
mindsight/_bundled/
