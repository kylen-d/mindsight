# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# macOS
.DS_Store

# Testing
.pytest_cache/

# Runtime outputs (anchored: mindsight/outputs/ is source, must stay visible)
/Outputs/
Projects/*/Outputs/
heatmaps/

